# Backend & Frontend Ports
BACKEND_PORT=10210
FRONTEND_PORT=10211

# Backend URLs (Replace with your actual domain or IP)
APP_URL="http://YOUR_IP_OR_DOMAIN:10210"
PUBLIC_FRONT_URL="http://YOUR_IP_OR_DOMAIN:10211"

# Frontend Gemini API Key
GEMINI_API_KEY="YOUR_FRONTEND_GEMINI_API_KEY"

# Backend Gemini API Keys for AI caller (you can input up to 3 keys for fallback rotation)
GEMINI_API_KEY_1="YOUR_BACKEND_GEMINI_API_KEY_1"
GEMINI_API_KEY_2="YOUR_BACKEND_GEMINI_API_KEY_2"
GEMINI_API_KEY_3="YOUR_BACKEND_GEMINI_API_KEY_3"
